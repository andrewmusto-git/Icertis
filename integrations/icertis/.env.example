# =============================================================================
# Icertis Source Configuration
# =============================================================================

# Icertis REST API URL for Users and Groups
# Pattern: https://<tenant>-api.icertis.com
ICERTIS_API_URL=https://yourcompany-api.icertis.com

# Icertis Business API URL for Org Units
# Pattern: https://<tenant>-business-api.icertis.com
ICERTIS_BUSINESS_API_URL=https://yourcompany-business-api.icertis.com

# OAuth2 Token endpoint
# Azure AD pattern: https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
ICERTIS_TOKEN_URL=https://login.microsoftonline.com/your-tenant-id/oauth2/v2.0/token

# OAuth2 Client Credentials
ICERTIS_CLIENT_ID=your_client_id_here
ICERTIS_CLIENT_SECRET=your_client_secret_here

# OAuth2 Scope (key: scope)
ICERTIS_SCOPE=api://6c49748d-db77-4577-b9d0-e31330bc889c/.default

# =============================================================================
# Veza Configuration
# =============================================================================

# Veza tenant URL (without trailing slash)
VEZA_URL=https://your-company.veza.com

# Veza API key  (generate in Veza → Administration → API Keys)
VEZA_API_KEY=your_veza_api_key_here

# =============================================================================
# OAA Provider Settings  (optional — override CLI defaults)
# =============================================================================

# PROVIDER_NAME=Icertis
# DATASOURCE_NAME=Icertis
